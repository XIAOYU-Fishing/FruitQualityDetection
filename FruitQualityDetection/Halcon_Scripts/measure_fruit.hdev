* 输入: FruitROI, FruitType, ScaleMmPerPixel
* 输出: ActualLengthMm, ActualWidthMm

if (FruitType == '苹果' or FruitType == '橘子')
    smallest_circle (FruitROI, Row, Column, Radius)
    DiameterPixel := Radius * 2
    ActualLengthMm := DiameterPixel * ScaleMmPerPixel
    ActualWidthMm := ActualLengthMm
else
    smallest_rectangle2 (FruitROI, Row, Column, Phi, Length1, Length2)
    ActualLengthMm := Length1 * 2 * ScaleMmPerPixel
    ActualWidthMm := Length2 * 2 * ScaleMmPerPixel
endif